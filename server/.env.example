# PostgreSQL Database Configuration 
PG_USER=postgres 
PG_HOST=localhost 
PG_DATABASE=apexops_db 
PG_PASSWORD=postgres 
PG_PORT=5432 

# Server Configuration 
PORT=3000 
NODE_ENV=development
# CORS: frontend origin (default http://localhost:5173), comma-separated for multiple
# CORS_ORIGIN=http://localhost:5173 

# JWT (use strong random secrets in production, min 32 chars)
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Auth rate limiting (per IP)
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX_LOGIN=10
# RATE_LIMIT_AUTH_MAX_REGISTER=5

# Password hashing (default 12)
# BCRYPT_ROUNDS=12

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

# Prisma (PostgreSQL). If DATABASE_URL is unset, it is built from PG_* above at runtime.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/apexops_db?schema=public"