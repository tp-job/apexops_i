generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Users ────────────────────────────────────────────────────
model User {
  id             Int       @id @default(autoincrement())
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  email          String    @unique
  password       String
  phone          String?
  company        String?
  position       String?
  location       String?
  timezone       String?   @default("Asia/Bangkok (GMT+7)")
  bio            String?
  avatarUrl      String?   @map("avatar_url")
  role           String?   @default("user")
  gender         String?
  birthDate      DateTime? @map("birth_date") @db.Date
  language       String?   @default("ไทย (Thai)")
  isActive       Boolean?  @default(true) @map("is_active")
  emailVerified  Boolean?  @default(false) @map("email_verified")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at")

  settings        UserSettings?
  notes           Note[]
  logs            Log[]
  refreshTokens   RefreshToken[]
  assignedTickets Ticket[] @relation("assignee")
  reportedTickets Ticket[] @relation("reporter")

  @@map("users")
}

// ── User Settings ────────────────────────────────────────────
model UserSettings {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique @map("user_id")
  emailNotifications Boolean  @default(true) @map("email_notifications")
  pushNotifications  Boolean  @default(true) @map("push_notifications")
  bugAlerts          Boolean  @default(true) @map("bug_alerts")
  weeklyReports      Boolean  @default(false) @map("weekly_reports")
  teamUpdates        Boolean  @default(true) @map("team_updates")
  twoFactorAuth      Boolean  @default(false) @map("two_factor_auth")
  sessionTimeout     Int      @default(30) @map("session_timeout")
  loginAlerts        Boolean  @default(true) @map("login_alerts")
  profileVisibility  Boolean  @default(true) @map("profile_visibility")
  activityStatus     Boolean  @default(true) @map("activity_status")
  dataCollection     Boolean  @default(false) @map("data_collection")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ── Logs ─────────────────────────────────────────────────────
model Log {
  id        Int      @id @default(autoincrement())
  level     String
  message   String
  source    String?
  stack     String?
  userId    Int?     @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("logs")
}

// ── Notes ────────────────────────────────────────────────────
model Note {
  id             Int      @id @default(autoincrement())
  userId         Int?     @map("user_id")
  title          String
  content        String?
  type           String?  @default("text")
  isPinned       Boolean  @default(false) @map("is_pinned")
  color          String?
  tags           Json     @default("[]")
  imageUrl       String?  @map("image_url")
  linkUrl        String?  @map("link_url")
  checklistItems Json     @default("[]") @map("checklist_items")
  quote          Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isPinned])
  @@map("notes")
}

// ── Tickets ──────────────────────────────────────────────────
model Ticket {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  status      String?  @default("open")
  priority    String?  @default("medium")
  assignee    String?
  reporter    String?  @default("System")
  assigneeId  Int?     @map("assignee_id")
  reporterId  Int?     @map("reporter_id")
  tags        Json     @default("[]")
  relatedLogs Json     @default("[]") @map("related_logs")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  assigneeUser User? @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporterUser User? @relation("reporter", fields: [reporterId], references: [id], onDelete: SetNull)

  @@index([assigneeId])
  @@index([reporterId])
  @@index([status])
  @@map("tickets")
}

// ── Refresh Tokens ───────────────────────────────────────────
model RefreshToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}
